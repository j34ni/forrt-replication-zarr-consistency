{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.bash_history)",
      "Read(~/.zsh_history)",
      "Read(~/.python_history)",
      "Read(~/.psql_history)",
      "Read(~/Library/Keychains/**)",
      "Read(~/Library/Application Support/Google/Chrome/**)",
      "Read(~/Library/Application Support/Firefox/**)",
      "Read(/etc/shadow)",
      "Read(/etc/sudoers)",
      "Read(/private/etc/shadow)",
      "Read(/private/etc/sudoers)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Write(/etc/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(/etc/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(eval *)"
    ],
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Read(./.claude/**)",
      "Write(./.claude/**)",
      "Edit(./.claude/**)",
      "Read(./.github/**)",
      "Write(./.github/**)",
      "Edit(./.github/**)",
      "Read(.claude/**)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "Read(.github/**)",
      "Write(.github/**)",
      "Edit(.github/**)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find . *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(env)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(rm -rf .claude/skills/init-template*)",
      "Bash(rm -rf ./.claude/skills/init-template*)",
      "Bash(rm .claude/skills/init-template/*)",
      "Bash(mkdir *)",
      "Bash(mkdir -p *)",
      "Bash(touch *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(snakemake *)",
      "Bash(jupytext *)",
      "Bash(jupyter *)",
      "Bash(nbclient *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pixi *)",
      "Bash(mamba *)",
      "Bash(micromamba *)",
      "Bash(conda *)",
      "Bash(uv *)",
      "Bash(docker *)",
      "Bash(myst *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(rocrate *)",
      "Bash(java -jar *)",
      "Bash(curl -s -L -H *)",
      "Bash(curl -L -o *)"
    ]
  },
  "_comment": "Sandbox approach for forrt-replication-template. Read/Write/Edit are restricted to the repo directory plus an explicit deny list of known-sensitive paths under ~/ (SSH keys, AWS creds, shell history, browser data). Bash is permissive for the standard replication-pipeline tools (git, gh, snakemake, jupytext, jupyter, mamba, docker, myst, etc.) and denies destructive patterns (rm -rf at root, curl-piped-to-shell). NOTE: Claude Code's Bash sandboxing is string-matched, not path-tagged — a determined shell command can read files outside the repo. For stronger isolation, run Claude Code inside a container. See docs/ai-portability.md."
}
