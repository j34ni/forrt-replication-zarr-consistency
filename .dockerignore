# Pixi install cache — the image builds its own env via `pixi install --locked`
# from pixi.toml + pixi.lock. Shipping the host's .pixi/ (multi-GB) into the
# build context would balloon the upload time for nothing.
.pixi/

# Snakemake run cache and generated outputs — regenerated by the pipeline
# inside the container; not needed to build the image.
.snakemake/
results/
data/*
!data/.gitkeep
!data/README.md

# Generated notebooks (jupytext .py is the source of truth)
notebooks/*.ipynb
notebooks/.ipynb_checkpoints/
notebooks/figures/

# Version control and Claude tooling — irrelevant to the runtime image
.git/
.claude/

# MyST / Jupyter Book build output
_build/
public/
paper/_build/
paper/.tmp/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/

# Environment / OS / misc
.DS_Store
.env
docker-image.tar.gz
reference/
nanopubs/imported/
_template_from_prior/
