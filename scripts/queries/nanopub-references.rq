# Get all nanopubs that refer to a specified nanopub URI.
# Uses npa:networkGraph to efficiently find references.
# Excludes invalidated and superseded nanopubs.
# Also excludes comments, retractions and approval/disapproval.
#
# Placeholder: `?_nanopubUri` - URI: the URI of the nanopub to find references to.

prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>
prefix dct: <http://purl.org/dc/terms/>
prefix nt: <https://w3id.org/np/o/ntemplate/>

select ?np ?label ?date ?creator ?template where {
  # Use npa:networkGraph to find nanopubs that refer to the specified nanopub
  graph npa:networkGraph {
    ?np npa:refersToNanopub ?_nanopubUri .
  }
  
  # Get metadata from npa:graph and exclude invalidated/superseded nanopubs
  graph npa:graph {
    ?np npa:hasValidSignatureForPublicKeyHash ?pubkey .
    filter not exists { ?npx npx:invalidates ?np ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }
    # Exclude retractions (nanopubs that invalidate the target nanopub)
    filter not exists { ?np npx:invalidates ?_nanopubUri . }
    optional { ?np rdfs:label ?label . }
    ?np np:hasAssertion ?assertion ;
        dct:created ?date ;
        dct:creator ?creator .
  }
  
  # Exclude comments (assertion contains rdfs:comment about the target)
  filter not exists { graph ?assertion { ?_nanopubUri rdfs:comment ?_s . } }
  
  # Exclude approvals (assertion contains npx:approvesOf for the target)
  filter not exists { graph ?assertion { ?approver npx:approvesOf ?_nanopubUri . } }
  
  # Exclude disapprovals (assertion contains npx:disapprovesOf for the target)
  filter not exists { graph ?assertion { ?disapprover npx:disapprovesOf ?_nanopubUri . } }
  
  # Optionally get the template this nanopub was created from
  optional { graph npa:networkGraph { ?np nt:wasCreatedFromTemplate ?template . } }
}
order by desc(?date)
limit 100
